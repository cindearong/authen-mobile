{
  "expo": {
    "name": "Expenses & Places Pro",
    "slug": "notif-mobile",
    "version": "1.0.0",
    "scheme": "notifmobile",
    "orientation": "portrait",
    "icon": "./assets/icon.png", 
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.authen.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.authen.mobile",
      //"googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          //"apiKey": "AIzaSyAipxg8qHxTFQ-FIY_vcHUI66cSE8FLMeg"
          "apiKey": "AIzaSyC8w8Yi6FHz2PyYAUJvc0RCpFMOY10N3P0"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E6F4FE"
      }
    },
    "web": {
        "output": "single",
        "favicon": "./assets/favicon.png"
      },
    "plugins": [
      "expo-document-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "The app needs access to your camera to take photos of places."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow this app to use your location to save your favorite spots.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1062013777281-p9rb00oovj1grd68c27pfluot4hi8eqs"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0608b109-54b9-4a6e-93ca-cdd1cee5e809"
      }
    }
  }
}